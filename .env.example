# Backend API URL (Python FastAPI server with Ankr SDK)
VITE_API_URL=http://localhost:8000

# Ankr API Key - REQUIRED for Ankr RPC access
# Get your own API key at: https://www.ankr.com/rpc/
# Then copy it here (without quotes):
VITE_ANKR_API_KEY=your_ankr_api_key_here

# Alternative: Full RPC URL (if not using API key above)
# VITE_SOLANA_RPC=https://rpc.ankr.com/solana/YOUR_API_KEY
