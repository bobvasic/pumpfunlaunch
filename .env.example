# Backend API URL (Python FastAPI server with Ankr SDK)
VITE_API_URL=http://localhost:8000

# Ankr API Key - REQUIRED for Ankr RPC access
# Get your own API key at: https://www.ankr.com/rpc/
VITE_ANKR_API_KEY=your_ankr_api_key_here

# ============================================
# PINATA CLOUD CONFIGURATION (IPFS Uploads)
# ============================================
# Get these from: https://app.pinata.cloud/developers/keys
# 
# Use either:
# Option A: API Key + API Secret (recommended)
# Option B: JWT Token (alternative)

# Option A: API Key + API Secret
VITE_PINATA_API_KEY=your_pinata_api_key_here
VITE_PINATA_API_SECRET=your_pinata_api_secret_here

# Option B: JWT Token (if you prefer using JWT instead)
# VITE_PINATA_JWT=your_pinata_jwt_token_here

# Note: If both are provided, API Key + Secret takes priority
# If Pinata is not configured, the app will use mock uploads
